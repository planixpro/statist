RewriteEngine On

# Tracker — serve directly
RewriteRule ^tracker\.js$ tracker.js [L]

# Installer — serve directly
RewriteRule ^install.php$ install.php [L]

# Flags — static .webp
RewriteRule ^storage/flags/[a-z]{2}(-[a-z]+)?\.webp$ - [L]

# Assets — CSS/JS (serve directly)
RewriteRule ^assets/ - [L]

# Admin panel — no rewriting
RewriteRule ^list/ - [L]

# Everything else → index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]

<IfModule mod_headers.c>
    Header set X-Robots-Tag "noindex, nofollow"
</IfModule>
