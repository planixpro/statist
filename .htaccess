RewriteEngine On

RewriteRule ^tracker\.js$ tracker.js [L]
RewriteRule ^install\.php$ install.php [L]
RewriteRule ^storage/flags/[a-z]{2}(-[a-z]+)?\.webp$ - [L]
RewriteRule ^assets/ - [L]
RewriteRule ^storage/ - [L]

RewriteRule ^list/?$ list/index.php [L,QSA]
RewriteRule ^list/(dashboard|sites|users|settings|stats|session|logout)/?$ list/$1.php [L,QSA]
RewriteRule ^list/ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]
RewriteRule ^api/collect$ index.php [L,QSA]

<IfModule mod_headers.c>
    Header set X-Robots-Tag "noindex, nofollow"
</IfModule>
